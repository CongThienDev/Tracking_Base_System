{
  "name": "tracking-base-system",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w @tracking-base/tracking-api build",
    "dev": "npm run -w @tracking-base/tracking-api dev",
    "start": "npm run -w @tracking-base/tracking-api start",
    "test": "npm run -w @tracking-base/tracking-api test",
    "migrate": "npm run -w @tracking-base/tracking-api migrate",
    "build:router-worker": "npm run -w @tracking-base/router-worker build",
    "dev:router-worker": "npm run -w @tracking-base/router-worker dev",
    "start:router-worker": "npm run -w @tracking-base/router-worker start",
    "test:router-worker": "npm run -w @tracking-base/router-worker test"
  }
}
