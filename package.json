{
  "name": "tracking-base-system",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w @tracking-base/tracking-api build",
    "build:console": "npm run -w @tracking-base/tracking-console build",
    "build:shared-contracts": "npm run -w @tracking-base/shared-contracts build",
    "dev:api": "npm run -w @tracking-base/tracking-api dev",
    "dev": "npm run -w @tracking-base/tracking-api dev",
    "dev:console": "npm run -w @tracking-base/tracking-console dev",
    "dev:worker": "npm run -w @tracking-base/router-worker dev",
    "dev:stack": "sh -c 'npm run dev:api & npm run dev:worker & wait'",
    "start:api": "npm run -w @tracking-base/tracking-api start",
    "start": "npm run -w @tracking-base/tracking-api start",
    "start:worker": "npm run -w @tracking-base/router-worker start",
    "start:stack": "sh -c 'npm run start:api & npm run start:worker & wait'",
    "preview:console": "npm run -w @tracking-base/tracking-console preview",
    "test": "npm run -w @tracking-base/tracking-api test",
    "test:shared-contracts": "npm run -w @tracking-base/shared-contracts test",
    "env:sync": "node scripts/env-sync.mjs sync",
    "env:check": "node scripts/env-sync.mjs check",
    "migrate": "npm run -w @tracking-base/tracking-api migrate",
    "validate:delete-by-user": "npm run -w @tracking-base/tracking-api validate:delete-by-user",
    "parity:check": "npm run -w @tracking-base/tracking-api parity:check --",
    "build:router-worker": "npm run -w @tracking-base/router-worker build",
    "dev:router-worker": "npm run -w @tracking-base/router-worker dev",
    "start:router-worker": "npm run -w @tracking-base/router-worker start",
    "test:router-worker": "npm run -w @tracking-base/router-worker test"
  }
}
